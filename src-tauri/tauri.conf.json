{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TIA Operator",
  "version": "0.1.2",
  "identifier": "ai.buildmind.tia-operator",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TIA Operator",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "msi"],
    "publisher": "Buildmind AI",
    "homepage": "https://github.com/ZhuXinAI/tia-operator",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENFRUU3NTI0RUU3QkRGMDUKUldRRjMzdnVKSFh1enBFLzlOSzcwU3BhRjJGVGZhUitxakJjeElwU3lxMXpVYjlodFc1WFcxNjMK",
      "endpoints": [
        "https://github.com/ZhuXinAI/tia-operator/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
